# HirePath Environment Configuration

# Ollama Settings
OLLAMA_ENDPOINT=https://api.ollama.com
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_MODEL=qwen3-next:80b-cloud
OLLAMA_TIMEOUT=60
OLLAMA_API_KEY=your_ollama_cloud_api_key
OLLAMA_AUTH_HEADER=Authorization

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Frontend Settings (if using resume-lm)
NEXT_PUBLIC_API_URL=https://your-backend-domain.com
NEXT_PUBLIC_RESUME_LM_URL=http://localhost:3000

# Paths
UPLOAD_FOLDER=./resume_uploads
JOB_FOLDER=./job_folder
SKILL_GAP_DB=./skill_gap_db

# Features
ENABLE_OLLAMA_FEATURES=true
ENABLE_JOB_MATCHING=true
ENABLE_GITHUB_ANALYSIS=true
ENABLE_INTERVIEW_PREP=true

# Limits
GITHUB_REPOS_MAX=100
JOB_MATCHES_DEFAULT=10
ATS_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
DEBUG_MODE=false
