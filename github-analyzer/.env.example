# GitHub Configuration
# Get your token from: https://github.com/settings/tokens
# Required scopes: repo, read:user
GITHUB_TOKEN=your_github_token_here

# Ollama LLM Configuration
# Download Ollama from: https://ollama.ai
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Application Settings
APP_PORT=8000

# ========================================
# SETUP INSTRUCTIONS:
# ========================================
# 1. Copy this file to .env:
#    cp .env.example .env  (macOS/Linux)
#    copy .env.example .env  (Windows)
#
# 2. Get GitHub Token:
#    - Go to https://github.com/settings/tokens
#    - Click "Generate new token (classic)"
#    - Select scopes: repo, read:user
#    - Copy token and replace "your_github_token_here" above
#
# 3. Install Ollama:
#    - Download from https://ollama.ai
#    - Install and run: ollama serve
#    - Pull a model: ollama pull qwen2.5:3b
#
# 4. Start the application:
#    python run.py
#
# ========================================
# RECOMMENDED OLLAMA MODELS:
# ========================================
# - qwen2.5:3b (Best balance - fast & accurate)
# - llama3.1:8b (Higher quality, slower)
# - mistral:latest (Good alternative)
# - gemma2:9b (Google's model)
#
# To change: ollama pull MODEL_NAME
# Then update OLLAMA_MODEL above
# ========================================

